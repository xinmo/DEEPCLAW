# ========== 数据库配置 ==========
DATABASE_URL=sqlite:///./javisagent.db

# ========== 文档解析模块 ==========
MINERU_API_TOKEN=your_mineru_api_token

# ========== 翻译模块 ==========
# ElevenLabs API (语音合成/克隆)
ELEVENLABS_API_KEY=your_elevenlabs_api_key

# DeepL API (可选)
DEEPL_API_KEY=your_deepl_api_key

# 科大讯飞 (iFlytek) API
XFYUN_APP_ID=your_xfyun_app_id
XFYUN_API_KEY=your_xfyun_api_key
XFYUN_API_SECRET=your_xfyun_api_secret

# ========== 知识库模块配置 ==========

# Milvus 向量数据库
MILVUS_HOST=localhost
MILVUS_PORT=19530

# OpenAI
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic Claude
ANTHROPIC_API_KEY=sk-xxx

# 智谱 AI
ZHIPU_API_KEY=xxx

# 阿里通义
DASHSCOPE_API_KEY=sk-xxx

# DeepSeek
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# ========== Claw 对话龙虾模块 ==========
# Tavily 网络搜索 API (可选，用于 web_search 工具)
TAVILY_API_KEY=tvly-xxx

# 知识库文件存储
KB_UPLOAD_DIR=./uploads/knowledge

# Rerank 模型
HF_ENDPOINT=https://hf-mirror.com

# 切片参数
CHUNK_SIZE=500
CHUNK_OVERLAP=100
